// app/api/folders/rename/route.ts
import { NextRequest, NextResponse } from 'next/server';
import { readFile, writeFile } from 'fs/promises';
import { existsSync } from 'fs';
import path from 'path';

// Extended interface med alla NextRequest properties
interface AuthenticatedRequest extends NextRequest {
  userId?: string;
  userEmail?: string;
}

function withAuth(handler: (req: AuthenticatedRequest) => Promise<NextResponse>) {
  return async (req: NextRequest) => {
    try {
      const authHeader = req.headers.get('Authorization');
      
      if (!authHeader) {
        return NextResponse.json(
          { error: 'No authorization header' }, 
          { status: 401 }
        );
      }

      const userData = JSON.parse(authHeader);
      
      if (!userData.id || !userData.email) {
        return NextResponse.json(
          { error: 'Invalid user data' }, 
          { status: 401 }
        );
      }

      const authReq = req as AuthenticatedRequest;
      authReq.userId = userData.id;
      authReq.userEmail = userData.email;

      return await handler(authReq);
      
    } catch (error) {
      console.error('Auth error:', error);
      return NextResponse.json(
        { error: 'Authentication failed' }, 
        { status: 401 }
      );
    }
  };
}

export const POST = withAuth(async (req: AuthenticatedRequest) => {
  try {
    console.log('✏️ Authenticated folder rename by user:', req.userId, req.userEmail);

    const { id, newName } = await req.json();

    if (!id || !newName?.trim()) {
      return NextResponse.json({ 
        success: false,
        error: 'Folder ID and new name are required' 
      }, { status: 400 });
    }

    const uploadsDir = path.join(process.cwd(), 'uploads');
    const metadataPath = path.join(uploadsDir, id + '.meta.json');

    if (!existsSync(metadataPath)) {
      return NextResponse.json({ 
        success: false,
        error: 'Folder not found' 
      }, { status: 404 });
    }

    try {
      // Read current metadata
      const metadataContent = await readFile(metadataPath, 'utf-8');
      const metadata = JSON.parse(metadataContent);
      
      // Update the original name
      metadata.originalName = newName.trim();
      
      // Save updated metadata
      await writeFile(metadataPath, JSON.stringify(metadata, null, 2));
      
      console.log('✅ Folder renamed by', req.userEmail, ':', metadata.originalName, '→', newName.trim());

      return NextResponse.json({
        success: true,
        message: 'Folder renamed successfully'
      });

    } catch (error: any) {
      console.error('Error reading/writing metadata:', error);
      return NextResponse.json({
        success: false,
        error: 'Failed to update folder metadata: ' + error.message
      }, { status: 500 });
    }

  } catch (error: any) {
    console.error('❌ Folder rename error:', error);
    return NextResponse.json({
      success: false,
      error: 'Failed to rename folder: ' + error.message
    }, { status: 500 });
  }
});